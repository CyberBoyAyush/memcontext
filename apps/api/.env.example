# MemContext API Environment Variables
# Copy this file to .env and fill in your values

# Database (Neon PostgreSQL with pgvector)
DATABASE_URL=postgres://username:password@hostname.neon.tech/database?sslmode=require

# AI Provider (OpenRouter)
OPENROUTER_API_KEY=sk-or-...

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Server Port (optional, defaults to 3000)
PORT=3000

# Environment (dev, production, test)
# - dev: logs to console with pretty formatting, no Better Stack
# - production: logs to Better Stack + stdout as JSON
NODE_ENV=dev

# Logging Level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Better Stack Logging (required for production)
# Get these from Better Stack dashboard -> Sources -> Create Source -> Node.js
LOGTAIL_SOURCE_TOKEN=
LOGTAIL_INGEST_ENDPOINT=https://s1234567.eu-nbg-2.betterstackdata.com

# Better Stack Query API (optional - for usage analytics in admin dashboard)
# Get these from Better Stack dashboard -> Dashboards -> Connect remotely -> ClickHouse HTTP client
BETTERSTACK_QUERY_ENDPOINT=https://eu-nbg-2-connect.betterstackdata.com
BETTERSTACK_QUERY_USER=
BETTERSTACK_QUERY_PASSWORD=
BETTERSTACK_SOURCE_TABLE=t123456_memcontext_api

# Better Auth Configuration (required for dashboard authentication)
# Secret key for signing cookies and JWTs - generate a random 32+ char string
BETTER_AUTH_SECRET=your-super-secret-key-at-least-32-chars

# Base URL of this API server (used by Better Auth)
BETTER_AUTH_URL=http://localhost:3000

# Dashboard URL (for CORS and redirects)
DASHBOARD_URL=http://localhost:3020

# Email auth
# Resend API key for verification and password reset emails
RESEND_API_KEY=re_...

# Verified sender address configured in Resend
EMAIL_FROM=MemContext <auth@your-domain.com>

# Cloudflare Turnstile SECRET key for server-side CAPTCHA validation
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth Providers
# Google OAuth - Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth - Get credentials from https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Cloudflare R2 document storage (Context Vault)
# Account ID from Cloudflare dashboard. Endpoint is derived as:
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Public/custom domain used by Mistral OCR and the dashboard to read originals.
# Example: https://files.your-domain.com
R2_PUBLIC_BASE_URL=

# Exa URL scraping/crawling for documentation and web pages (Context Vault)
EXA_API_KEY=

# Mistral OCR for PDFs, DOCX, and scanned/image documents (Context Vault)
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
