{
  "name": "memcontext-sdk",
  "version": "1.0.1",
  "description": "TypeScript SDK for the MemContext public API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "memcontext",
    "memory",
    "ai",
    "agents",
    "typescript",
    "sdk"
  ],
  "homepage": "https://memcontext.in",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyberBoyAyush/memcontext.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/CyberBoyAyush/memcontext/issues"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.9.2"
  },
  "license": "GPL-3.0"
